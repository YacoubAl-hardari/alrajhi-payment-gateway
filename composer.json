{
    "name": "alrajhi/payment-gateway",
    "description": "Clean Laravel package for Al Rajhi Bank Payment Gateway - Bank Hosted Integration Only",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "alrajhi", "payment", "bank-hosted", "gateway", "api-only"],
    "authors": [
        {
            "name": "Yacoub Al-haidari",
            "email": "yacoub@yacoubalhaidari.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "laravel/framework": "^10.0|^11.0|^12.0",
        "guzzlehttp/guzzle": "^7.2"
    },
    "autoload": {
        "psr-4": {
            "AlRajhi\\PaymentGateway\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AlRajhi\\PaymentGateway\\AlRajhiPaymentServiceProvider"
            ],
            "aliases": {
                "AlRajhiPayment": "AlRajhi\\PaymentGateway\\Facades\\AlRajhiPayment"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
